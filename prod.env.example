# Conscience Research production service environment
CONSCIENCE_HOST=0.0.0.0
CONSCIENCE_PORT=8080

# Service starts in baseline oracle mode for evaluation endpoints.
# Override per request when needed.
CONSCIENCE_ORACLE_MODE=baseline
CONSCIENCE_SCENARIO_EDIT_MODE=off

# Chat/classifier model defaults can be overridden without code changes.
CONSCIENCE_CHAT_MODEL=claude-sonnet-4-6
CONSCIENCE_CLASSIFIER_MODEL=claude-haiku-4-5-20251001
CONSCIENCE_MAX_HISTORY_LINES=1000
CONSCIENCE_LOAD_PERSONA_THRESHOLDS=1
